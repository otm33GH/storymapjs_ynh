APPLICATION_DOMAINS=__DOMAIN__
FLASK_ENV=production
FLASK_SECRET_KEY=__SECRET_KEY__
FLASK_SETTINGS_FILE=core/settings.py
FLASK_SETTINGS_MODULE=storymap.core.settings
STATIC_URL=/static/

PG_ENGINE=postgres
PG_HOST=localhost
PG_NAME=__DB_NAME__
PG_PORT=5432
PG_USER=__DB_USER__
PG_PASSWORD=__DB_PWD__

STORYMAPJS_DIRECTORY=__DATA_DIR__

AWS_ACCESS_KEY_ID=__S3_ACCESS_KEY__
AWS_SECRET_ACCESS_KEY=__S3_SECRET_KEY__
AWS_STORAGE_BUCKET_NAME=__S3_BUCKET_NAME__
AWS_STORAGE_BUCKET_KEY=storymapjs
AWS_STORAGE_BUCKET_URL=__S3_ENDPOINT__/storymapjs/
AWS_ENDPOINT_URL=__S3_ENDPOINT__/


CDN_URL=https://cdn.knightlab.com/libs/storymapjs/latest/

YNH_AUTH_MODE=__AUTH_MODE__
GOOGLE_CLIENT_ID=__GOOGLE_CLIENT_ID__
GOOGLE_CLIENT_SECRET=__GOOGLE_CLIENT_SECRET__

MAPBOX_API_KEY=
ADMINS=
